# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.
# In production, set these in Netlify → Site settings → Environment variables.

# Example: if you add a paid data provider in the future
# MARKET_DATA_API_KEY=your_key_here
# ALPHA_VANTAGE_KEY=your_key_here

# Rate limit (requests per minute per IP, applied to all /api/* functions)
RATE_LIMIT_RPM=30
